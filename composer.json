{
    "name": "phumtech/laravel-pdf-compress",
    "description": "Professional Laravel package to compress and optimize PDF files using qpdf and Ghostscript binaries.",
    "keywords": [
        "laravel",
        "pdf",
        "compress",
        "compressor",
        "optimize",
        "optimizer",
        "qpdf",
        "ghostscript",
        "files",
        "phumtech"
    ],
    "homepage": "https://github.com/PhumTech/laravel-pdf-compress",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "PhumTech",
            "email": "chheanlymeng.dev@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "symfony/process": "^6.0|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "PhumTech\\PdfCompress\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhumTech\\PdfCompress\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhumTech\\PdfCompress\\PhumTechPdfCompressServiceProvider"
            ],
            "aliases": {
                "PdfCompress": "PhumTech\\PdfCompress\\Facades\\PdfCompress"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
